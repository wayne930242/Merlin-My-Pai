{{ vault_web_domain }} {
    encode gzip

    # Redirect /protect to /protect/
    redir /protect /protect/ 308

    # All /protect/* - strip prefix then route
    handle_path /protect/* {
        # API proxy to bot
        handle /api/* {
            reverse_proxy localhost:3000
        }

        # WebSocket proxy
        handle /ws {
            reverse_proxy localhost:3000
        }

        # SPA static files
        handle {
            root * /home/{{ ansible_user }}/pai-web
            try_files {path} /index.html
            file_server
        }
    }

    # Root - simple index page
    handle {
        root * /home/{{ ansible_user }}/pai-web-root
        file_server
    }
}
